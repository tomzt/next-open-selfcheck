# ============================================================
# open-selfcheck — Kiosk Configuration
# Copy to .env and fill in your values
# ============================================================

# App
NODE_ENV=production
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change-this-to-a-random-secret

# ── Branding & Identity (set for your library) ───────────────
# Library name — shown in <title>, headers, and email receipts.
# KIOSK_LIBRARY_NAME applies to all locales; the TH/EN variants override.
# Leave blank to use the neutral default ("Library" / "ห้องสมุด").
KIOSK_LIBRARY_NAME=
KIOSK_LIBRARY_NAME_TH=
KIOSK_LIBRARY_NAME_EN=

# Logo & welcome video — three ways to provide each, tried in order:
#   1. URL env var below (absolute https://… or root-relative /path)
#   2. Drop a file in public/branding/ (logo.svg/png/jpg/webp, welcome.mp4/webm/mov)
#   3. Leave unset → asset is omitted, UI hides it gracefully
KIOSK_LOGO_URL=
KIOSK_WELCOME_VIDEO_URL=

# Which menu services this kiosk offers — comma separated, no spaces.
# Remove a service to hide its button on the menu (route is also blocked
# from direct access). Useful e.g. when returns go through a Bookdrop
# station only and this kiosk should not accept returns.
# Options: borrow, return, loans, fines. Unset or blank = all enabled.
KIOSK_SERVICES=borrow,return,loans,fines

# ── SIP2 ────────────────────────────────────────────────────
SIP2_HOST=192.168.1.100
SIP2_PORT=6002
# Institution code (AO field in SIP2 messages) — matches your ILS library code
SIP2_INSTITUTION=LIBRARY
# Automation account credentials for SIP2 Login (message 93)
# Leave blank if your ILS does not require a login before patron queries
SIP2_LOGIN_USER=
SIP2_LOGIN_PASSWORD=
SIP2_TIMEOUT_MS=5000
SIP2_RETRY_COUNT=3
SIP2_RETRY_DELAY_SECONDS=2
# Currency shown for fines if the ILS omits the BH field in its response
SIP2_DEFAULT_CURRENCY=THB
# No separate "mock mode" — for local dev, just point SIP2_HOST at the
# mock server (packages/sip2-client, see its README) instead of a real ILS.

# ── Auth Mode ────────────────────────────────────────────────
# barcode (default) — patron card / QR scan validated via SIP2
# oidc              — institutional SSO only (Keycloak, Azure AD, Auth0…)
# both              — patron can choose either method
AUTH_MODE=barcode

# Require PIN in addition to card scan? (true | false, default: false)
# Useful for libraries that enforce PIN-based authentication.
AUTH_PIN_REQUIRED=false

# ── OIDC Provider (required only when AUTH_MODE=oidc or both) ─
# Works with any OpenID Connect provider — Keycloak, Azure AD, Auth0, etc.
# Keycloak: https://keycloak.example.com/realms/library
# Azure AD: https://login.microsoftonline.com/{tenant}/v2.0
OIDC_ISSUER=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
# Label shown on the sign-in button
OIDC_PROVIDER_NAME=Institutional SSO
# Which OIDC claim carries the patron ID used by the ILS (SIP2 AA field)?
# - preferred_username (default) — Keycloak login username, often = student/staff ID
# - student_id / library_barcode / employee_number — if your IdP exposes them
# Must resolve to the same identifier the ILS expects, or SIP2 queries will fail.
OIDC_PATRON_ID_CLAIM=preferred_username

# ── Email receipt (replaces printed slip — docs/requirements.md §6) ──
# disabled = no email sent (default-safe); smtp = send via SMTP below.
# resend / sendgrid are reserved for future contribution, not implemented yet.
EMAIL_PROVIDER=disabled
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=library@example.com
EMAIL_SUBJECT_TH=ห้องสมุด — สรุปการยืม/คืน
EMAIL_SUBJECT_EN=Library — Transaction Receipt

# ── RFID (optional) ─────────────────────────────────────────
RFID_ENABLED=false
RFID_DRIVER=webserial

# ── Database (PostgreSQL) ────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=selfcheck
POSTGRES_USER=selfcheck
POSTGRES_PASSWORD=change-this-password
DATABASE_URL=postgresql://selfcheck:change-this-password@postgres:5432/selfcheck

# ── Session & Screensaver ────────────────────────────────────
SESSION_TIMEOUT_MINUTES=3
SCREENSAVER_TIMEOUT_MINUTES=5

# ── UI Defaults ──────────────────────────────────────────────
# th | en (or any locale added under messages/)
NEXT_PUBLIC_DEFAULT_LANGUAGE=th
# light | dark | colorful | glass | material
NEXT_PUBLIC_KIOSK_THEME=light
# small | medium | large | xlarge — patron can still change it at runtime
# via the accessibility bar; this only sets what they see on first load.
NEXT_PUBLIC_DEFAULT_FONT_SIZE=medium
# mouse (default) | touch — touch hides the cursor and disables hover
# effects, since a stuck :hover state after tapping looks broken.
NEXT_PUBLIC_INPUT_MODE=mouse
