# ============================================================
# open-selfcheck — Kiosk Configuration
# Copy to .env and fill in your values
# ============================================================

# App
NODE_ENV=production
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change-this-to-a-random-secret

# ── SIP2 ────────────────────────────────────────────────────
SIP2_HOST=192.168.1.100
SIP2_PORT=6002
SIP2_INSTITUTION_ID=
SIP2_CHECKSUM_ENABLED=false
SIP2_INSTITUTION_LOGIN_ENABLED=false
SIP2_INSTITUTION_LOGIN_ID=
SIP2_INSTITUTION_LOGIN_PASSWORD=
SIP2_TIMEOUT_SECONDS=3
SIP2_RETRY_COUNT=3
SIP2_RETRY_DELAY_SECONDS=2
# Set to 'mock' during development (no real ILS needed)
SIP2_MODE=production

# ── Auth Provider ────────────────────────────────────────────
# Options: keycloak | credentials | (add your own)
AUTH_PROVIDER=keycloak

# Keycloak (if AUTH_PROVIDER=keycloak)
KEYCLOAK_ISSUER=https://your-keycloak/realms/your-realm
KEYCLOAK_CLIENT_ID=
KEYCLOAK_CLIENT_SECRET=

# ── RFID (optional) ─────────────────────────────────────────
RFID_ENABLED=false
RFID_DRIVER=webserial

# ── Database (PostgreSQL) ────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=selfcheck
POSTGRES_USER=selfcheck
POSTGRES_PASSWORD=change-this-password
DATABASE_URL=postgresql://selfcheck:change-this-password@postgres:5432/selfcheck

# ── Session & Screensaver ────────────────────────────────────
SESSION_TIMEOUT_MINUTES=3
SCREENSAVER_TIMEOUT_MINUTES=5

# ── UI Defaults ──────────────────────────────────────────────
DEFAULT_LANGUAGE=th
DEFAULT_THEME=light
DEFAULT_FONT_SIZE=medium
INPUT_MODE=mouse
