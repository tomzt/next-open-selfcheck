# ============================================================
# open-selfcheck — Workstation Configuration
# Copy to .env and fill in your values
# ============================================================

# App
NODE_ENV=production
PORT=3001

# ── RFID ─────────────────────────────────────────────────────
RFID_ENABLED=true
RFID_DRIVER=webserial
# Your library's identifier — written into every RFID tag
LIBRARY_CODE=your-library-code

# ── Staff Auth ───────────────────────────────────────────────
# Change these before deployment!
STAFF_AUTH_SECRET=change-this-to-a-random-secret
STAFF_AUTH_USER=admin
STAFF_AUTH_PASSWORD=change-this-password

# ── ILS Lookup (optional) ────────────────────────────────────
# Enable to look up item title by barcode before programming tag
ILS_LOOKUP_ENABLED=false
ILS_LOOKUP_URL=
# Options: z3950 | alist-api
ILS_LOOKUP_PROTOCOL=z3950

# ── UI Defaults ──────────────────────────────────────────────
DEFAULT_LANGUAGE=th
